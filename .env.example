# ==========================================
# Telegram OpenCode Bot - example config
# ==========================================

# Required: token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:replace_me

# Required: your numeric Telegram from.id
ALLOWED_USER_ID=123456789

# Optional: extra allowed users, comma-separated
# ALLOWED_USER_IDS=111111111,222222222

# Adapter mode: http | cli | pty
OPEN_CODE_ADAPTER=http

# Required in HTTP mode. Optional in CLI/PTy mode.
OPEN_CODE_URL=http://localhost:3000/opencode/query
OPEN_CODE_TOKEN=dev-token

# General behavior
OPEN_CODE_TIMEOUT_MS=8000
OPEN_CODE_CONTROL_TIMEOUT_MS=8000
OPEN_CODE_EXEC_TIMEOUT_MS=8000
POLLING_INTERVAL_MS=1500
LOCALE=es

# Persistence
STATE_DRIVER=sqlite
STATE_DB_PATH=./data/telegram-opencode.sqlite
STATE_JSON_PATH=./data/telegram-opencode-state.json

# Compatibility / boot / concurrency
COMPAT_LEGACY_TEXT_BRIDGE=true
COMPAT_RUN_CMD_COMMANDS=true
BOOT_REMOTE_RECONCILE=true
CHAT_LOCK_ENABLED=true
LOCK_WARN_WAIT_MS=1500

# Watcher / webhook local loopback
WATCHER_ENABLED=true
WATCHDOG_ENABLED=true
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT_START=4040
WEBHOOK_PORT_END=4045
WATCHDOG_INTERVAL_MS=15000
WATCHDOG_STALE_AFTER_MS=60000
WATCHDOG_MAX_RETRY_COUNT=3

# Human prompts
HUMAN_PROMPTS_ENABLED=false
HUMAN_PROMPT_LOCAL_TTL_MS=300000
